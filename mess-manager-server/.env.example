# Mess Manager Backend Configuration

# MongoDB Connection String (Atlas or Local)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/mess-manager?retryWrites=true&w=majority

# JWT Authentication Secret (Use a strong unique string)
JWT_SECRET=your_super_secret_jwt_key_here

# Server Port
PORT=5000

# Client URL (Use your Vercel URL in production)
CLIENT_URL=https://your-mess-manager.vercel.app
